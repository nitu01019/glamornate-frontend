# =============================================================================
# Glamornate Frontend — Environment Variables
# Copy this file to `.env.local` for web dev or `.env.mobile` for Capacitor.
# =============================================================================

# ---- API base URL (Team C §R1) ---------------------------------------------
# Web dev / Vercel SSR: leave as `/api/v1` so the client hits local Next routes.
# Mobile (Capacitor) builds: point directly to the Firebase Functions v2 URL.
#   e.g. https://asia-south1-glamornate-758c6.cloudfunctions.net/api/v1
NEXT_PUBLIC_API_BASE_URL=/api/v1

# ---- Firebase Client SDK ---------------------------------------------------
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ---- Firebase Admin (server-side only) -------------------------------------
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

# ---- Firebase App Check (Team C §R5) ---------------------------------------
# ReCaptcha v3 public site key from the Firebase App Check console.
# Required for both dev (.env.local) and prod (.env.production). When unset,
# providers.tsx → initAppCheck() silently skips → enforcement breaks on flip-on.
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=[REDACTED_RECAPTCHA_SITE_KEY]
# Set to `true` during local development to print a debug token in the browser
# console. Register that token in the Firebase App Check console, then ENSURE
# this flag is `false` (or unset) for production builds.
NEXT_PUBLIC_APP_CHECK_DEBUG=false
# Stable App Check debug token (UUID v4). Local dev only — used together with
# NEXT_PUBLIC_APP_CHECK_DEBUG=true. Generate via:
#   node -e "console.log(crypto.randomUUID())"
# Then register ONCE in Firebase Console → App Check → Manage debug tokens
# for EACH service (Auth, Firestore, Functions, Storage). Never commit a real value.
NEXT_PUBLIC_APP_CHECK_DEBUG_TOKEN=[REDACTED_DEBUG_TOKEN_UUID]

# ---- Build metadata (Team D §R6/N4 cache-buster) ---------------------------
# Tied to the React Query persister `buster` key so cache invalidates per deploy.
NEXT_PUBLIC_APP_VERSION=0.0.1

# ---- Home surface ----------------------------------------------------------
# NEXT_PUBLIC_HOME_V2_HERO — set to "1" to enable the Phase-1 clean hero carousel (default: disabled).
NEXT_PUBLIC_HOME_V2_HERO=
# NEXT_PUBLIC_HOME_V2_GRID — set to "1" to enable the Phase-1 13-tile big-tile category grid (default: disabled; legacy 4-per-row grid stays).
NEXT_PUBLIC_HOME_V2_GRID=

# ---- Sentry — set before production deploy. Empty DSN = Sentry disabled (no-op). -------------------
# Public mirror: SENTRY_ORG / SENTRY_PROJECT no longer have defaults — operators
# must supply their own values via CI/Vercel env vars. Build succeeds without
# them but sourcemap upload is skipped.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_AUTH_TOKEN=          # only needed for sourcemap upload at build time
SENTRY_ORG=
SENTRY_PROJECT=

# ---- Google Maps (booking location capture) --------------------------------
# Public-by-design — restricted by HTTP referrer + Android package + SHA-1.
# Required for Places Autocomplete + draggable map pin on the booking
# location step. When unset, MapsKeyMissingFallback renders a typed-only form.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# ---- Environment label -----------------------------------------------------
# Used by app-check-debug gating, Sentry environment tag, etc.
NEXT_PUBLIC_ENVIRONMENT=development

# ---- Feature flags (NEXT_PUBLIC_* — visible to client) ---------------------
# See src/lib/flags/ for the full set of flags.
