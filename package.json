{
  "name": "web",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.0.0 <25.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "analyze": "ANALYZE=true next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf .next node_modules",
    "optimize:images": "node scripts/optimize-images.mjs",
    "generate:blur": "node scripts/generate-blur.mjs",
    "prebuild": "node scripts/optimize-images.mjs && node scripts/generate-blur.mjs",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "build:mobile": "bash scripts/build-mobile.sh",
    "build:mobile:release": "bash scripts/release-build.sh",
    "build:mobile:staging": "bash scripts/staging-release-build.sh",
    "build:mobile:debug": "bash scripts/release-build.sh && cd android && ./gradlew assembleDebug",
    "mobile:sweep": "bash scripts/sweep-icloud-ghosts.sh",
    "cap:sync": "npx cap sync",
    "cap:open:android": "npx cap open android",
    "cap:open:ios": "npx cap open ios",
    "lighthouse": "lhci autorun",
    "lighthouse:mobile": "lhci autorun --config=./lighthouserc.mobile.cjs",
    "lighthouse:all": "pnpm lighthouse && pnpm lighthouse:mobile",
    "smoke:staging": "tsx scripts/smoke-staging.ts"
  },
  "dependencies": {
    "@capacitor-community/privacy-screen": "^6.1.0",
    "@capacitor-firebase/app-check": "^8.2.0",
    "@capacitor-firebase/authentication": "^8.2.0",
    "@capacitor-firebase/messaging": "^8.2.0",
    "@capacitor/android": "^8.3.1",
    "@capacitor/app": "^8.1.0",
    "@capacitor/cli": "^8.3.1",
    "@capacitor/core": "^8.3.1",
    "@capacitor/geolocation": "^8.0.0",
    "@capacitor/ios": "^8.3.1",
    "@capacitor/keyboard": "^8.0.3",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@glamornate/contracts": "workspace:*",
    "@glamornate/data-catalog": "workspace:*",
    "@hookform/resolvers": "^3.3.4",
    "@radix-ui/react-avatar": "^1.0.4",
    "@radix-ui/react-checkbox": "^1.0.4",
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-label": "^2.0.2",
    "@radix-ui/react-popover": "^1.0.7",
    "@radix-ui/react-radio-group": "^1.1.3",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-separator": "^1.0.3",
    "@radix-ui/react-slot": "^1.0.2",
    "@radix-ui/react-tabs": "^1.0.4",
    "@radix-ui/react-toast": "^1.1.5",
    "@radix-ui/react-tooltip": "^1.0.7",
    "@sentry/capacitor": "^3.2.1",
    "@sentry/nextjs": "10.43.0",
    "@tanstack/query-sync-storage-persister": "^5.99.0",
    "@tanstack/react-query": "^5.17.19",
    "@tanstack/react-query-persist-client": "^5.99.0",
    "@vis.gl/react-google-maps": "^1.5.0",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.0",
    "date-fns": "^3.3.1",
    "date-fns-tz": "^3.2.0",
    "firebase": "^12.11.0",
    "firebase-admin": "^13.8.0",
    "lucide-react": "^0.316.0",
    "nanoid": "^5.0.4",
    "next": "15.5.15",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.49.3",
    "server-only": "^0.0.1",
    "tailwind-merge": "^2.2.1",
    "zod": "^3.22.4",
    "zustand": "^4.4.7"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@capacitor/assets": "^3.0.5",
    "@capacitor/push-notifications": "^8.0.3",
    "@lhci/cli": "^0.15.1",
    "@next/bundle-analyzer": "^16.2.4",
    "@playwright/test": "^1.59.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.11.5",
    "@types/react": "^18.2.48",
    "@types/react-dom": "^18.2.18",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.3",
    "autoprefixer": "^10.4.17",
    "eslint": "^8.56.0",
    "eslint-config-next": "15.1.3",
    "jsdom": "^29.0.2",
    "msw": "^2.13.4",
    "postcss": "^8.4.33",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.1",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.19.2",
    "typescript": "^5.3.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^4.1.3"
  }
}
