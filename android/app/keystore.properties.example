# ----------------------------------------------------------------------------
# Glamornate Android release signing credentials — template.
#
# 1. Copy this file to android/app/keystore.properties
# 2. Fill in the four values below with the details from your upload keystore
#    (see docs/runbooks/android-keystore-setup.md).
# 3. NEVER commit the filled-in file. The root .gitignore already excludes
#    android/app/keystore.properties and any *.keystore / *.jks files.
#
# Paths are resolved relative to android/app/ when not absolute, so dropping
# the .keystore next to this file and using its bare filename is enough.
# ----------------------------------------------------------------------------

# Path to the upload keystore (relative to android/app/ or absolute).
storeFile=glamornate-upload.keystore

# Keystore password you set during `keytool -genkey`.
storePassword=REPLACE_WITH_STORE_PASSWORD

# Alias of the signing key inside the keystore (-alias flag of keytool).
keyAlias=glamornate-upload

# Password for the key alias. Can match storePassword.
keyPassword=REPLACE_WITH_KEY_PASSWORD
