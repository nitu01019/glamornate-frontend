<?xml version="1.0" encoding="utf-8"?>
<!--
  Network security config for Glamornate.
  - Production: cleartext traffic disabled, system CAs only.
  - Debug: system + user CAs allowed for dev proxies (Charles, mitmproxy).
  Cert pinning to prod API host is an optional follow-up — see
  docs/remediation/PHASE-1-BLOCKERS.md.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system"/>
        </trust-anchors>
    </base-config>
    <!--
      Emulator + localhost: cleartext allowed so the WebView can reach
      `npx cap serve` / `next dev` on 10.0.2.2 (Android emulator's host
      loopback) or localhost. These addresses are unroutable from outside
      the device, so allowing cleartext here cannot leak production traffic.

      Lint rule: `<domain-config>` must live at the top level of
      `<network-security-config>` — nesting it inside `<debug-overrides>`
      triggers `Nested <domain-config> elements are not allowed in
      debug-overrides`.
    -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">10.0.2.2</domain>
        <domain includeSubdomains="true">127.0.0.1</domain>
        <domain includeSubdomains="true">localhost</domain>
    </domain-config>
    <debug-overrides>
        <trust-anchors>
            <certificates src="system"/>
            <certificates src="user"/>
        </trust-anchors>
    </debug-overrides>
</network-security-config>
