# Glamornate Frontend — local development env (copy to `.env.local`).
# Canonical schema lives in `.env.example` — keep these in sync.

# API base URL — web dev uses local Next routes under /api/v1.
NEXT_PUBLIC_API_BASE_URL=/api/v1

# Firebase Client Config
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin (server-side)
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

# Firebase App Check (web uses ReCaptcha v3)
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=
NEXT_PUBLIC_APP_CHECK_DEBUG=true

# Build metadata
NEXT_PUBLIC_APP_VERSION=0.0.1

# Google Maps (booking location capture) — leave empty to exercise fallback.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
